{
  "name": "hono-typescript-bun-template",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "start": "bun src/server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "bunx biome check .",
    "format": "bunx biome format --write .",
    "test": "NODE_ENV=test LOG_LEVEL=error LOG_PRETTY=false TRACE_ENABLED=false vitest run",
    "test:watch": "NODE_ENV=test LOG_LEVEL=error LOG_PRETTY=false TRACE_ENABLED=false vitest",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,json,md,yml,yaml}": "bunx biome check --write --no-errors-on-unmatched"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.2",
    "@hono/swagger-ui": "^0.5.2",
    "dotenv": "^17.3.1",
    "hono": "^4.9.7",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@types/node": "^24.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.6",
    "typescript": "^5.9.2",
    "vitest": "^4.0.0"
  }
}
