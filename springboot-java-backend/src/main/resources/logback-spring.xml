<configuration>
  <springProperty name="LOG_LEVEL" source="app.log-level" defaultValue="INFO"/>

  <appender name="PRETTY" class="ch.qos.logback.core.ConsoleAppender">
    <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
      <pattern>%d{yyyy-MM-dd'T'HH:mm:ss.SSSX} %-5level %logger{36} - %replace(%msg){'(?i)(authorization|password|token)=([^\s,]+)', '$1=[REDACTED]'}%n</pattern>
    </encoder>
  </appender>

  <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
    <encoder class="net.logstash.logback.encoder.LogstashEncoder">
      <customFields>{"service":"springboot-java-backend"}</customFields>
    </encoder>
  </appender>

  <springProfile name="production">
    <root level="${LOG_LEVEL}">
      <appender-ref ref="JSON"/>
    </root>
  </springProfile>

  <springProfile name="!production">
    <root level="${LOG_LEVEL}">
      <appender-ref ref="PRETTY"/>
    </root>
  </springProfile>
</configuration>
